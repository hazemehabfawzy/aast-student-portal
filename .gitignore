# ===========================
# AAST Student Portal
# .gitignore
# ===========================

# Database (contains real student data - never commit)
data/student_portal.db
data/*.db
**/*.db
**/*.db-shm
**/*.db-wal

# Firebase credentials (sensitive - never commit)
StudentPortal.Api/firebase-service-account.json
mobile/android/app/google-services.json

# Environment files
.env
.env.local
.env.production
*.env
**/.env
**/.env.local
**/.env.production

# .NET / ASP.NET Core
bin/
obj/
*.user
*.suo
*.userosscache
*.vs/
*.rsuser
*.pfx
*.publishsettings

# Node / Frontend
node_modules/
frontend/dist/
frontend/build/
.npm

# Flutter / Mobile
mobile/build/
mobile/.dart_tool/
mobile/.flutter-plugins
mobile/.flutter-plugins-dependencies
mobile/.packages
mobile/pubspec.lock
**/*.hprof

# Python / Face Service
__pycache__/
*.pyc
*.pyo
face-service/__pycache__/
face-service/*.pkl

# Keycloak
keycloak/data/

# IDE and OS
.idea/
.DS_Store
Thumbs.db

# Sensitive config
**/local.properties
**/*.pfx
**/*.p12
StudentPortal.Api/appsettings.Development.json

# Logs
*.log
logs/
